#比较运算符
flag0=1==1
flag1=1<2
flag2=1>2
print('flag0是',flag0)
print('flag1是',flag1)
print('flag2是',flag2)
"""
flag0是 True
flag1是 True
flag2是 False
"""
#逻辑运算符
flag3=flag0 and flag1
flag4=flag1 or flag2
flag5= not flag3
