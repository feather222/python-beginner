#eg2圆的周长与面积计算
import math
radius=float(input('输入圆的半径值'))
perimeter=2*math.pi*radius
area=math.pi*radius**2
print(f'该圆的周长是{perimeter:.2f}')
print(f'{area:.3f}是该圆的面积')
print('%.3f是该圆的周长'%perimeter)
print('该圆的面积是%.2f'%area)
     
